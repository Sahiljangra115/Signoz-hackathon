  "variables": {},
  "version": "v5",
  "widgets": [
    {
      "description": "p99 duration of POST /chat spans. Alert LatencyLeech fires above 2s.",
      "fillSpans": false,
      "id": "mib-widget-1",
      "isStacked": false,
      "nullZeroValues": "zero",
      "opacity": "1",
      "panelTypes": "graph",
      "query": {
        "panelType": "graph",
        "queries": [
          {
            "spec": {
              "aggregations": [
                {
                  "expression": "p99(duration_nano)"
                }
              ],
              "disabled": false,
              "filter": {
                "expression": "service.name = 'city' AND name = 'POST /chat'"
              },
              "groupBy": [],
              "having": {
                "expression": ""
              },
              "legend": "p99",
              "name": "A",
              "order": [],
              "signal": "traces",
              "source": "",
              "stepInterval": 60
            },
            "type": "builder_query"
          }
        ],
        "queryType": "builder",
        "unit": "ns"
      },
      "softMax": null,
      "softMin": null,
      "timePreferance": "GLOBAL_TIME",
      "title": "Chat p99 latency (Latency Leech)",
      "yAxisUnit": "ns"
    },
    {
      "description": "Share of city spans carrying an error. Alert ErrorSwarm fires above 20%.",
      "fillSpans": false,
      "id": "mib-widget-2",
      "isStacked": false,
      "nullZeroValues": "zero",
      "opacity": "1",
      "panelTypes": "graph",
      "query": {
        "panelType": "graph",
        "queries": [
          {
            "spec": {
              "aggregations": [
                {
                  "expression": "count()"
                }
              ],
              "disabled": false,
              "filter": {
                "expression": "hasError = true"
              },
              "groupBy": [],
              "having": {
                "expression": ""
              },
              "legend": "errors",
              "name": "A",
              "order": [],
              "signal": "traces",
              "source": "",
              "stepInterval": 60
            },
            "type": "builder_query"
          },
          {
            "spec": {
              "aggregations": [
                {
                  "expression": "count()"
                }
              ],
              "disabled": false,
              "filter": {
                "expression": "service.name = 'city'"
              },
              "groupBy": [],
              "having": {
                "expression": ""
              },
              "legend": "all",
              "name": "B",
              "order": [],
              "signal": "traces",
              "source": "",
              "stepInterval": 60
            },
            "type": "builder_query"
          },
          {
            "spec": {
              "expression": "(A / B) * 100",
              "legend": "error %",
              "name": "F1"
            },
            "type": "builder_formula"
          }
        ],
        "queryType": "builder",
        "unit": "percent"
      },
      "softMax": null,
      "softMin": null,
      "timePreferance": "GLOBAL_TIME",
      "title": "Error rate % (Error Swarm)",
      "yAxisUnit": "percent"
    },
