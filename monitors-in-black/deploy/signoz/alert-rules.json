[
  {
    "alert": "ErrorSwarm",
    "alertType": "TRACES_BASED_ALERT",
    "ruleType": "threshold_rule",
    "condition": {
      "compositeQuery": {
        "queries": [
          {
            "type": "builder_query",
            "spec": {
              "name": "A",
              "stepInterval": 0,
              "signal": "traces",
              "source": "",
              "aggregations": [
                {
                  "expression": "count()"
                }
              ],
              "filter": {
                "expression": "hasError = true"
              },
              "having": {
                "expression": ""
              }
            }
          },
          {
            "type": "builder_query",
            "spec": {
              "name": "B",
              "stepInterval": 0,
              "signal": "traces",
              "source": "",
              "aggregations": [
                {
                  "expression": "count()"
                }
              ],
              "filter": {
                "expression": "serviceName = 'city'"
              },
              "having": {
                "expression": ""
              }
            }
          },
          {
            "type": "builder_formula",
            "spec": {
              "name": "F1",
              "expression": "(A / B) * 100"
            }
          }
        ],
        "panelType": "graph",
        "queryType": "builder",
        "unit": "s"
      },
      "selectedQueryName": "F1",
      "thresholds": {
        "kind": "basic",
        "spec": [
          {
            "name": "critical",
            "target": 20,
            "targetUnit": "min",
            "recoveryTarget": null,
            "matchType": "at_least_once",
            "op": "above",
            "channels": [
              "mib-hq"
            ]
          }
        ]
      }
    },
    "annotations": {
      "description": "This alert is fired when the defined metric (current value: {{$value}}) crosses the threshold ({{$threshold}})",
      "summary": "This alert is fired when the defined metric (current value: {{$value}}) crosses the threshold ({{$threshold}})"
    },
    "disabled": false,
    "version": "v5",
    "evaluation": {
      "kind": "rolling",
      "spec": {
        "evalWindow": "5m0s",
        "frequency": "1m"
      }
    },
    "schemaVersion": "v2alpha1",
    "notificationSettings": {
      "renotify": {
        "enabled": false,
        "interval": "30m"
      }
    }
  },
  {
